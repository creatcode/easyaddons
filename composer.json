{
    "name": "creatcode/easyaddons",
    "description": "TP6+FastAdmin风格项目的专用插件包",
    "license": "Apache-2.0",
    "keywords": [
        "thinkphp6",
        "thinkphp8",
        "addons",
        "project-package"
    ],
    "require": {
        "php": ">=7.1.0",
        "topthink/framework": "^6.1|^7.0|^8.0",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/var-exporter": "^5.4|^6.0|^7.0",
        "nelexa/zip": "^3.3 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "creatcode\\easyaddons\\": "src/"
        },
        "files": [
            "src/helper.php"
        ]
    },
    "extra": {
        "think": {
            "services": [
                "creatcode\\easyaddons\\AddonService"
            ],
            "config": {
                "addons": "src/config.php",
                "easyaddons": "src/easyaddons.php"
            }
        }
    }
}
